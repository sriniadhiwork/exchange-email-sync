# Microsoft Azure AD App Registration
# Create at: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
# 1. Register new app, set redirect URI to http://localhost:8400
# 2. Under "API permissions", add Microsoft Graph -> Mail.ReadWrite
# 3. Under "Certificates & secrets", create a client secret
MICROSOFT_CLIENT_ID=your-client-id-here
MICROSOFT_CLIENT_SECRET=your-client-secret-here

# Google Cloud Console OAuth 2.0 Credentials
# Create at: https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID (Desktop app)
# 2. Enable Gmail API at: https://console.cloud.google.com/apis/library/gmail.googleapis.com
GOOGLE_CLIENT_ID=your-client-id-here
GOOGLE_CLIENT_SECRET=your-client-secret-here
